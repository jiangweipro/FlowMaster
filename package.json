{
  "name": "flowmaster-dashboard",
  "displayName": "FlowMaster Dashboard",
  "description": "Visual workflow dashboard for OpenFlow demand lifecycle management in VS Code",
  "version": "1.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jiangweipro/FlowMaster"
  },
  "publisher": "flowmaster",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "workflow",
    "openflow",
    "project-management",
    "demand",
    "claude",
    "ai",
    "lifecycle"
  ],
  "icon": "media/icon-128.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "activationEvents": [
    "onCommand:flowmaster.openDashboard",
    "onView:flowmaster-sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "flowmaster.openDashboard",
        "title": "FlowMaster: Open Dashboard"
      },
      {
        "command": "flowmaster.refresh",
        "title": "FlowMaster: Refresh Dashboard"
      },
      {
        "command": "flowmaster.newDemand",
        "title": "FlowMaster: New Demand"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "flowmaster-sidebar-container",
          "title": "FlowMaster",
          "icon": "$(git-branch)"
        }
      ]
    },
    "views": {
      "flowmaster-sidebar-container": [
        {
          "type": "webview",
          "id": "flowmaster-sidebar",
          "name": "Dashboard"
        }
      ]
    },
    "configuration": {
      "title": "FlowMaster",
      "properties": {
        "flowmaster.statePath": {
          "type": "string",
          "default": ".workflow/state",
          "description": "Relative path from workspace root to the OpenFlow state directory"
        },
        "flowmaster.autoRefresh": {
          "type": "boolean",
          "default": true,
          "description": "Automatically refresh state when dashboard opens"
        }
      }
    }
  },
  "scripts": {
    "bump-version": "node scripts/bump-version.js",
    "precompile": "npm run bump-version",
    "compile": "tsc -p tsconfig.json",
    "watch": "tsc -watch -p tsconfig.json",
    "lint": "tsc --noEmit --strict",
    "test": "vitest run",
    "test:watch": "vitest",
    "generate-icon": "node scripts/generate-icon.js",
    "prepackage": "npm run compile",
    "package": "npx vsce package",
    "publish": "npx vsce publish"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "yaml": "^2.7.0"
  }
}
